{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [
			"ESNext",
			"DOM"
		],
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": [
			"vite/client"
		]
	},
	"include": [
		"src"
	],
	"extends": "./.svelte-kit/tsconfig.json"
}